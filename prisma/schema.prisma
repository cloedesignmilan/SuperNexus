generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  email               String?  @unique
  password            String?
  role                String   @default("admin") // admin, user, client
  bot_pin                 String?  @unique
  telegram_chat_id        String?  @unique // Salva il chat ID quando si collega dal bot
  subscription_active     Boolean  @default(true)
  paypal_subscription_id  String?  @unique
  subscription_status     String?  @default("active")
  subscription_expires_at DateTime?
  images_allowance        Int      @default(10) // Limite credito totale attuale
  base_allowance          Int      @default(10) // Limite ricaricato ogni mese
  images_generated        Int      @default(0) // Consumo totale nel ciclo
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  telegram_configs TelegramConfig[]
  categories       Category[]
  jobs             GenerationJob[]
}

model TelegramConfig {
  id                 String   @id @default(uuid())
  user_id            String
  telegram_bot_token String
  telegram_chat_id   String
  is_active          Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Category {
  id          String   @id @default(uuid())
  user_id     String
  name        String
  slug        String   @unique
  description String?  @db.Text
  cover_image String?
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  is_locked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  business_modes BusinessMode[]
  jobs           GenerationJob[]
}

model BusinessMode {
  id                  String   @id @default(uuid())
  category_id         String
  name                String
  slug                String   @unique
  description         String?  @db.Text
  cover_image         String?
  default_image_count Int      @default(4)
  sort_order          Int      @default(0)
  is_active           Boolean  @default(true)
  is_locked           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  category      Category        @relation(fields: [category_id], references: [id], onDelete: Cascade)
  subcategories Subcategory[]
  jobs          GenerationJob[]
}

model Subcategory {
  id                     String   @id @default(uuid())
  business_mode_id       String
  name                   String
  slug                   String   @unique
  description            String?  @db.Text
  preview_image          String?
  max_images_allowed     Int      @default(10)
  style_type             String?
  output_goal            String?
  business_context       String?
  visual_priority        Int      @default(0)
  internal_notes         String?  @db.Text
  sort_order             Int      @default(0)
  is_active              Boolean  @default(true)
  is_locked              Boolean  @default(false)
  strict_reference_mode  Boolean  @default(false)
  active_model           String?
  scene_variance_active  Boolean?
  
  // Campi integrati da ex PromptTemplateSettings
  base_prompt_prefix      String?  @db.Text
  product_integrity_rules String?  @db.Text
  negative_prompt         String?  @db.Text
  output_language         String   @default("it")

  // App 2.0 God Mode Configs (JSON)
  allowed_models          Json?
  allowed_environments    Json?
  supported_aspect_ratios Json?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  business_mode    BusinessMode                @relation(fields: [business_mode_id], references: [id], onDelete: Cascade)
  reference_images SubcategoryReferenceImage[]
  variations       SubcategoryVariation[]
  jobs             GenerationJob[]
  validation_checks OutputValidationCheck[]
}

model SubcategoryReferenceImage {
  id             String   @id @default(uuid())
  subcategory_id String
  image_url      String
  title          String?
  caption        String?  @db.Text
  storage_path   String?
  image_order    Int      @default(0)
  is_active      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subcategory Subcategory @relation(fields: [subcategory_id], references: [id], onDelete: Cascade)
}

model OutputValidationCheck {
  id                       String   @id @default(uuid())
  subcategory_id           String
  reference_image_url      String
  generated_sample_image   String
  comparison_status        String   @default("pending") // match, partial, incorrect
  review_notes             String?  @db.Text
  last_checked_at          DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  subcategory Subcategory @relation(fields: [subcategory_id], references: [id], onDelete: Cascade)
}

model SubcategoryVariation {
  id               String   @id @default(uuid())
  subcategory_id   String
  variation_code   String
  variation_name   String
  variation_prompt String   @db.Text
  sort_order       Int      @default(0)
  is_active        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subcategory Subcategory @relation(fields: [subcategory_id], references: [id], onDelete: Cascade)
}

model GenerationJob {
  id                            String   @id @default(uuid())
  user_id                       String
  category_id                   String
  business_mode_id              String
  subcategory_id                String
  original_product_image_url    String
  original_product_storage_path String?
  status                        String   @default("pending")
  selected_shot_type            String?
  custom_notes                  String?  @db.Text
  prompt_generated              String?  @db.Text
  provider_name                 String?
  provider_response             String?  @db.Text
  error_message                 String?  @db.Text
  results_count                 Int      @default(0)
  total_cost_eur                Float    @default(0.0)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [category_id], references: [id], onDelete: Cascade)
  business_mode BusinessMode @relation(fields: [business_mode_id], references: [id], onDelete: Cascade)
  subcategory  Subcategory  @relation(fields: [subcategory_id], references: [id], onDelete: Cascade)
  images       JobImage[]
}

model JobImage {
  id           String   @id @default(uuid())
  job_id       String
  image_url    String
  storage_path String?
  image_order  Int      @default(0)
  createdAt    DateTime @default(now())

  job GenerationJob @relation(fields: [job_id], references: [id], onDelete: Cascade)
}

model ApiCostLog {
  id          String   @id @default(uuid())
  user_id     String?
  action_type String
  model_used  String
  tokens_in   Int      @default(0)
  tokens_out  Int      @default(0)
  cost_eur    Float    @default(0.0)
  createdAt   DateTime @default(now())
}

model Setting {
  key   String @id
  value String @db.Text
}

model PromptSnippet {
  id                     String   @id @default(uuid())
  snippet_type           String   
  label                  String
  description            String?  @db.Text
  icon                   String?  // Nome icona lucide-react o emoji
  visual_style           String?  // catalog, ugc, lifestyle, premium, ads, generic
  prompt_fragment        String?  @db.Text
  negative_fragment      String?  @db.Text
  priority_order         Int      @default(0)
  sort_group             String?  @default("Recommended") // Recommended, Ecommerce, Social, Premium, Other styles
  intensity_level        String   @default("medium") // soft, medium, strong
  is_recommended         Boolean  @default(false)
  is_active              Boolean  @default(true)
  recommended_for        String?  @db.Text
  incompatibilities      String?  @db.Text
  admin_notes            String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model PromptConfigShot {
  id              String   @id @default(uuid())
  category        String
  mode            String
  presentation    String
  scene           String   @default("all")
  aspectRatio     String?
  shotNumber      Int
  shotName        String
  positivePrompt  String   @db.Text
  negativePrompt  String   @db.Text
  hardRules       String   @db.Text
  outputGoal      String?  @db.Text
  imageUrl        String?  @db.Text
  priority        Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([category, mode, presentation, scene, aspectRatio, shotNumber])
}
