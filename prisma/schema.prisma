generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  telegram_bot_token  String?
  monthly_fee         Float    @default(0)
  is_active           Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  users               User[]
  jobs                GenerationJob[]
  templates           PromptTemplate[]
  default_template_id String?
  password            String?
  default_template    PromptTemplate? @relation("StoreDefaultTemplate", fields: [default_template_id], references: [id])
  
  // -- BILLING & GENERATION LIMITS --
  plan_name              String   @default("STARTER") // e.g. "STARTER", "BOUTIQUE", "ENTERPRISE"
  generation_limit       Int      @default(50)         // Number of images allowed per month
  subscription_credits   Int      @default(50)         // Current cycle remaining credits
  supplementary_credits  Int      @default(0)          // Extra purchased credits that rollover
  billing_cycle_start    DateTime @default(now())      // Auto-reset anchor date
}

model User {
  id              String   @id @default(uuid())
  telegram_id     String?  @unique
  role            String   @default("user") // admin, user, store_manager
  store_id        String?
  store           Store?   @relation(fields: [store_id], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GenerationJob {
  id                  String      @id @default(uuid())
  original_image_url  String
  status              String      @default("in lavorazione") // in lavorazione, completato, errore
  target_template_id  String?
  results_count       Int         @default(10)
  store_id            String?
  store               Store?      @relation(fields: [store_id], references: [id], onDelete: Cascade)
  telegram_chat_id    String?
  metadata            Json?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  images              JobImage[]
  logs                ErrorLog[]
}

model JobImage {
  id                  String         @id @default(uuid())
  job_id              String
  job                 GenerationJob  @relation(fields: [job_id], references: [id], onDelete: Cascade)
  image_url           String
  scene_type          String?
  createdAt           DateTime       @default(now())
}

model PromptTemplate {
  id          String   @id @default(uuid())
  name        String
  category    String
  base_prompt String   @db.Text
  rules       String   @db.Text
  num_images  Int      @default(10)
  scenes      String   @db.Text // JSON string list of scenes
  store_id    String?
  store       Store?   @relation(fields: [store_id], references: [id], onDelete: Cascade)
  defaultForStores Store[] @relation("StoreDefaultTemplate")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ErrorLog {
  id          String         @id @default(uuid())
  job_id      String?
  job         GenerationJob? @relation(fields: [job_id], references: [id], onDelete: SetNull)
  message     String         @db.Text
  createdAt   DateTime       @default(now())
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- NEW MODULAR PROMPT ARCHITECTURE ---

model Category {
  id               String   @id @default(uuid())
  parent_id        String?
  parent           Category?  @relation("SubCategories", fields: [parent_id], references: [id])
  children         Category[] @relation("SubCategories")
  name             String
  description      String?  @db.Text
  age_range        String?
  child_age_range  String?
  is_active        Boolean  @default(true)
  sort_order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prompt_master PromptMaster?
  scenes        Scene[]
}

model PromptMaster {
  id             String   @id @default(uuid())
  category_id    String   @unique
  category       Category @relation(fields: [category_id], references: [id], onDelete: Cascade)
  title          String
  prompt_text    String   @db.Text
  negative_rules String?  @db.Text
  studio_prompts String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Scene {
  id          String   @id @default(uuid())
  category_id String
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)
  title       String
  scene_text  String   @db.Text
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
